GEMINI_API_KEY=your-gemini-key-here
# Flash for triage — comma-separated fallbacks tried in order on 404/429
GEMINI_TRIAGE_MODEL=gemini-2.5-flash,gemini-3.5-flash
# Flash for drafting on free tier; add gemini-2.5-pro first when billing is enabled
GEMINI_DRAFT_MODEL=gemini-2.5-flash,gemini-3.5-flash
# Leave unset — low values truncate drafts (FinishReason.MAX_TOKENS)
# GEMINI_DRAFT_MAX_TOKENS=
TRIAGE_USE_STUB=0
DRAFT_USE_STUB=0
GEMINI_CONCURRENCY=1
# Use 5 when TRIAGE_USE_STUB=1 and DRAFT_USE_STUB=1 (no live Gemini quota pressure)
# Token-saving Gemini demo pair (one RED + one YELLOW):
#   email-001 = RED  — "Bathroom ceiling water stain"
#   email-006 = YELLOW — "Drippy faucet follow-up"
# Do NOT use email-007 here — it is also RED (city code violation).
GEMINI_LIVE_ONLY_IDS=email-001,email-006
MCP_SERVICE_TOKEN=dev-token-placeholder
MCP_BASE_URL=http://localhost:8000
DB_URL=sqlite:///nightshift.db
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
# Use in-memory spans locally (no collector required). Set to 0 to export OTLP.
OTEL_USE_MEMORY=1
